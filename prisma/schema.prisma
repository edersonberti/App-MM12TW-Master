// Prisma schema — Supabase PostgreSQL (profiles, devices, device_settings)
// Introspectado e alinhado ao banco real em 2026-07-14. Docs: prisma/README.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Perfis de usuário (id = auth.users.id do Supabase Auth)
model Profile {
  id        String   @id @db.Uuid
  email     String   @unique @db.Text
  fullName  String?  @map("full_name") @db.Text
  role      String?  @default("operator") @db.Text
  createdAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  devices Device[]

  @@index([email], map: "idx_profiles_email")
  @@index([role], map: "idx_profiles_role")
  @@map("profiles")
}

/// Equipamentos IoT registrados por usuário
model Device {
  id           String   @id @db.Text
  model        String   @db.Text
  pairingToken String?  @map("pairing_token") @db.Text
  userId       String?  @map("user_id") @db.Uuid
  createdAt    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("created_at") @db.Timestamptz(6)

  profile        Profile?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceSettings DeviceSettings?

  @@index([userId], map: "idx_devices_user_id")
  @@index([model], map: "idx_devices_model")
  @@map("devices")
}

/// Nomes customizados dos motores (até 8) por equipamento
model DeviceSettings {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId   String   @unique @map("device_id") @db.Text
  motor1Name String?  @default("Motor 01") @map("motor1_name") @db.Text
  motor2Name String?  @default("Motor 02") @map("motor2_name") @db.Text
  motor3Name String?  @default("Motor 03") @map("motor3_name") @db.Text
  motor4Name String?  @default("Motor 04") @map("motor4_name") @db.Text
  motor5Name String?  @default("Motor 05") @map("motor5_name") @db.Text
  motor6Name String?  @default("Motor 06") @map("motor6_name") @db.Text
  motor7Name String?  @default("Motor 07") @map("motor7_name") @db.Text
  motor8Name String?  @default("Motor 08") @map("motor8_name") @db.Text
  updatedAt  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @map("updated_at") @db.Timestamptz(6)

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("device_settings")
}
